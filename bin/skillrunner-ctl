#!/usr/bin/env bash
set -euo pipefail

SKILLRUNNER_HOME="${XDG_CONFIG_HOME:-${HOME}/.config}/skillrunner"
CONFIG_FILE="${SKILLRUNNER_HOME}/config.json"

SKILLRUNNER_LIB="${SKILLRUNNER_LIB:-$(cd "$(dirname "$0")/../lib" && pwd)}"
source "${SKILLRUNNER_LIB}/logging.sh"

ensure_config() {
    mkdir -p "${SKILLRUNNER_HOME}"/{logs/output,locks}
    if [[ ! -f "$CONFIG_FILE" ]]; then
        echo '{"version": 1, "projects": [], "schedules": []}' | jq . > "$CONFIG_FILE"
    fi
    if [[ ! -f "${SKILLRUNNER_HOME}/state.json" ]]; then
        echo '{"last_wake": null, "pid": null, "version": 1}' | jq . > "${SKILLRUNNER_HOME}/state.json"
    fi
}

# sync_skills — clone or update skill dependencies declared in .skillrunner.json
# Skills are installed into <project>/.claude/skills/<name>/
sync_skills() {
    local project_path="$1"
    local project_config="${project_path}/.skillrunner.json"

    local skill_count
    skill_count=$(jq '.skills // [] | length' "$project_config")
    [[ "$skill_count" -eq 0 ]] && return 0

    local skills_dir="${project_path}/.claude/skills"
    mkdir -p "$skills_dir"

    echo "Syncing ${skill_count} skill dependency(ies)..."

    for ((i = 0; i < skill_count; i++)); do
        local name git_url ref
        name=$(jq -r ".skills[$i].name" "$project_config")
        git_url=$(jq -r ".skills[$i].git" "$project_config")
        ref=$(jq -r ".skills[$i].ref // \"main\"" "$project_config")

        local skill_dir="${skills_dir}/${name}"

        if [[ -z "$name" || "$name" == "null" || -z "$git_url" || "$git_url" == "null" ]]; then
            echo "  SKIP: skill entry $i is missing name or git url"
            continue
        fi

        if [[ -d "$skill_dir/.git" ]]; then
            # Existing clone — fetch and checkout the right ref
            echo "  Updating skill '${name}' (${ref})..."
            (cd "$skill_dir" && git fetch origin --quiet && git checkout "$ref" --quiet 2>/dev/null && git pull origin "$ref" --quiet 2>/dev/null) || {
                echo "  WARNING: Failed to update skill '${name}'"
                continue
            }
        else
            # Fresh clone
            echo "  Cloning skill '${name}' from ${git_url} (${ref})..."
            rm -rf "$skill_dir"
            git clone --quiet --branch "$ref" "$git_url" "$skill_dir" 2>/dev/null || {
                # Branch might not exist as a branch name, try clone + checkout
                git clone --quiet "$git_url" "$skill_dir" 2>/dev/null && \
                    (cd "$skill_dir" && git checkout "$ref" --quiet 2>/dev/null) || {
                    echo "  ERROR: Failed to clone skill '${name}' from ${git_url}"
                    continue
                }
            }
        fi

        # Verify the skill has a SKILL.md
        if [[ -f "${skill_dir}/SKILL.md" ]]; then
            echo "  OK: skill '${name}' installed at .claude/skills/${name}/"
        else
            echo "  WARNING: skill '${name}' cloned but no SKILL.md found in repo root"
        fi
    done
}

cmd_register() {
    local project_path="${1:-.}"
    project_path="$(cd "$project_path" && pwd)"

    local project_config="${project_path}/.skillrunner.json"
    if [[ ! -f "$project_config" ]]; then
        echo "ERROR: No .skillrunner.json found in ${project_path}"
        exit 1
    fi

    ensure_config

    # Remove existing schedules for this project
    local tmp
    tmp=$(mktemp)
    jq --arg pp "$project_path" '
        .schedules = [.schedules[] | select(.project_path != $pp)] |
        .projects = [.projects[] | select(.path != $pp)]
    ' "$CONFIG_FILE" > "$tmp" && mv "$tmp" "$CONFIG_FILE"

    # Read project config and merge schedules
    local now_iso
    now_iso=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    # Add project entry
    tmp=$(mktemp)
    jq --arg pp "$project_path" --arg ts "$now_iso" '
        .projects += [{"path": $pp, "registered_at": $ts}]
    ' "$CONFIG_FILE" > "$tmp" && mv "$tmp" "$CONFIG_FILE"

    # Add each schedule with generated ID
    local count
    count=$(jq '.schedules | length' "$project_config")

    for ((i = 0; i < count; i++)); do
        local sid
        sid=$(openssl rand -hex 4)

        tmp=$(mktemp)
        jq --arg pp "$project_path" --arg sid "$sid" --arg ts "$now_iso" \
            --argjson sched "$(jq -c ".schedules[$i]" "$project_config")" '
            .schedules += [$sched + {
                "id": $sid,
                "project_path": $pp,
                "registered_at": $ts
            }]
        ' "$CONFIG_FILE" > "$tmp" && mv "$tmp" "$CONFIG_FILE"
    done

    echo "Registered ${count} schedule(s) from ${project_path}"

    # Sync skill dependencies
    sync_skills "$project_path"
}

cmd_unregister() {
    local project_path="${1:-.}"
    project_path="$(cd "$project_path" && pwd)"

    local tmp
    tmp=$(mktemp)
    jq --arg pp "$project_path" '
        .schedules = [.schedules[] | select(.project_path != $pp)] |
        .projects = [.projects[] | select(.path != $pp)]
    ' "$CONFIG_FILE" > "$tmp" && mv "$tmp" "$CONFIG_FILE"

    echo "Unregistered all schedules for ${project_path}"
}

cmd_status() {
    echo "=== SkillRunner Status ==="

    # Check daemon (systemd or launchctl)
    if systemctl --user is-active skillrunner.timer &>/dev/null; then
        echo "Daemon: RUNNING (systemd timer)"
    elif launchctl list 2>/dev/null | grep -q "com.skillrunner.daemon"; then
        echo "Daemon: RUNNING (LaunchAgent)"
    else
        echo "Daemon: STOPPED"
    fi

    if [[ -f "${SKILLRUNNER_HOME}/state.json" ]]; then
        echo "Last wake: $(jq -r '.last_wake // "never"' "${SKILLRUNNER_HOME}/state.json")"
    fi

    if [[ -f "$CONFIG_FILE" ]]; then
        local sched_count proj_count
        sched_count=$(jq '.schedules | length' "$CONFIG_FILE")
        proj_count=$(jq '.projects | length' "$CONFIG_FILE")
        echo "Projects: ${proj_count}"
        echo "Schedules: ${sched_count}"
    fi

    if [[ -f "${SKILLRUNNER_HOME}/logs/runs.jsonl" ]]; then
        echo ""
        echo "Last 5 runs:"
        tail -5 "${SKILLRUNNER_HOME}/logs/runs.jsonl" | \
            jq -r '"  \(.started_at) | \(.name) | \(.status) | \(.duration_seconds)s | $\(.cost_usd // "n/a")"'
    fi
}

cmd_list() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        echo "No schedules configured."
        exit 0
    fi
    jq -r '.schedules[] |
        "\(.id)\t\(.type // "skill")\t\(.skill // .command // "")\t\(.cron)\t\(.human_schedule // "")\t\(.enabled)\t\(.project_path)"
    ' "$CONFIG_FILE" | column -t -s $'\t' -N "ID,Type,Name,Cron,Schedule,Enabled,Project"
}

case "${1:-help}" in
    register)   cmd_register "${2:-}" ;;
    unregister) cmd_unregister "${2:-}" ;;
    status)     cmd_status ;;
    list)       cmd_list ;;
    *)
        echo "Usage: skillrunner-ctl {register|unregister|status|list} [path]"
        exit 1
        ;;
esac
