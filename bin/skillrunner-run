#!/usr/bin/env bash
set -euo pipefail

# Executes a single scheduled skill run.
# Usage: skillrunner-run <schedule_id>

SKILLRUNNER_HOME="${XDG_CONFIG_HOME:-${HOME}/.config}/skillrunner"
CONFIG_FILE="${SKILLRUNNER_HOME}/config.json"
RUNS_LOG="${SKILLRUNNER_HOME}/logs/runs.jsonl"
OUTPUT_DIR="${SKILLRUNNER_HOME}/logs/output"

# Add common NixOS/nix profile paths so we can find claude, git, etc.
for p in "$HOME/.nix-profile/bin" "/etc/profiles/per-user/$(whoami)/bin" "/run/current-system/sw/bin" "/run/wrappers/bin"; do
    [[ -d "$p" ]] && PATH="${p}:${PATH}"
done

SKILLRUNNER_LIB="${SKILLRUNNER_LIB:-$(cd "$(dirname "$0")/../lib" && pwd)}"
source "${SKILLRUNNER_LIB}/logging.sh"
source "${SKILLRUNNER_LIB}/lock.sh"
source "${SKILLRUNNER_LIB}/notify.sh"

SCHEDULE_ID="$1"

# Top-level error trap: if anything fails before normal completion,
# log the error and attempt to send a failure notification.
_early_failure() {
    local exit_code=$?
    local line_no="${1:-unknown}"
    # Log the crash — logging.sh is already sourced at this point
    log_daemon "RUN CRASH: Schedule ${SCHEDULE_ID} failed at line ${line_no} (exit ${exit_code}) before run could complete"

    # Attempt to send a failure notification using the schedule's notification config
    local schedule_json
    schedule_json=$(jq -c ".schedules[] | select(.id == \"${SCHEDULE_ID}\")" "$CONFIG_FILE" 2>/dev/null || true)
    if [[ -n "$schedule_json" ]]; then
        local has_notification
        has_notification=$(echo "$schedule_json" | jq -e '.notification' 2>/dev/null) || true
        if [[ -n "$has_notification" ]]; then
            local skill_name
            skill_name=$(echo "$schedule_json" | jq -r '.skill // .command // "unknown"')

            # Build destinations array (supports both legacy and multi-destination)
            local dests
            dests=$(echo "$schedule_json" | jq -c '
                .notification |
                if .destinations then
                    [.destinations[] | {
                        service: (.service // "telegram"),
                        destination: (if .service == "discord" then .webhook_url else .chat_id end)
                    }]
                else
                    [{
                        service: (.service // "telegram"),
                        destination: (if (.service // "telegram") == "discord" then .webhook_url else .chat_id end)
                    }]
                end
            ' 2>/dev/null || echo '[]')

            local dest_count
            dest_count=$(echo "$dests" | jq 'length')

            # Load secrets once for potential Telegram sends
            local token_file="${SKILLRUNNER_HOME}/secrets.env"
            if [[ -f "$token_file" ]]; then
                # shellcheck source=/dev/null
                source "$token_file"
            fi
            local token="${SKILLRUNNER_TELEGRAM_TOKEN:-}"

            local i svc dest
            for (( i = 0; i < dest_count; i++ )); do
                svc=$(echo "$dests" | jq -r ".[$i].service")
                dest=$(echo "$dests" | jq -r ".[$i].destination")
                if [[ "$svc" == "discord" && -n "$dest" ]]; then
                    local msg="❌ **${skill_name}** crashed during initialization (line ${line_no}, exit ${exit_code})"
                    local payload
                    payload=$(jq -cn --arg content "$msg" '{content: $content}')
                    curl -s -X POST -H "Content-Type: application/json" \
                        -d "$payload" "$dest" >/dev/null 2>&1 || true
                    log_daemon "RUN CRASH: Failure notification sent via Discord"
                elif [[ -n "$token" && -n "$dest" ]]; then
                    local msg="❌ *${skill_name}* crashed during initialization (line ${line_no}, exit ${exit_code})"
                    curl -s -X POST "https://api.telegram.org/bot${token}/sendMessage" \
                        --data-urlencode "chat_id=$dest" \
                        --data-urlencode "parse_mode=Markdown" \
                        --data-urlencode "text=$msg" \
                        --data-urlencode "disable_web_page_preview=true" >/dev/null 2>&1 || true
                    log_daemon "RUN CRASH: Failure notification sent to chat ${dest}"
                fi
            done
        fi
    fi

    # Clean up lock if it was acquired
    release_lock "$SCHEDULE_ID" 2>/dev/null || true
}
trap '_early_failure ${LINENO}' ERR

RUN_ID=$(openssl rand -hex 8)

# Read schedule config
schedule_json=$(jq -c ".schedules[] | select(.id == \"${SCHEDULE_ID}\")" "$CONFIG_FILE")
if [[ -z "$schedule_json" ]]; then
    log_daemon "ERROR: Schedule ${SCHEDULE_ID} not found in config"
    exit 1
fi

run_type=$(echo "$schedule_json" | jq -r '.type // "skill"')
workdir=$(echo "$schedule_json" | jq -r '.project_path // env.HOME')
timeout_secs=$(echo "$schedule_json" | jq -r '.timeout_seconds // 300')
max_attempts=$(echo "$schedule_json" | jq -r '.retry.max_attempts // 1')
retry_delay=$(echo "$schedule_json" | jq -r '.retry.delay_seconds // 60')

# Type-specific fields
skill=""
args=""
command=""
permission_mode="plan"
max_budget="0.50"
use_chrome="false"

if [[ "$run_type" == "skill" ]]; then
    skill=$(echo "$schedule_json" | jq -r '.skill')
    args=$(echo "$schedule_json" | jq -r '.args // ""')
    permission_mode=$(echo "$schedule_json" | jq -r '.permission_mode // "plan"')
    max_budget=$(echo "$schedule_json" | jq -r '.max_budget_usd // 0.50')
    use_chrome=$(echo "$schedule_json" | jq -r '.chrome // false')
elif [[ "$run_type" == "command" ]]; then
    command=$(echo "$schedule_json" | jq -r '.command')
fi

# Display name for logging
run_name="${skill:-${command}}"

# Acquire lock (atomic mkdir)
acquire_lock "$SCHEDULE_ID" || {
    log_daemon "Failed to acquire lock for ${SCHEDULE_ID}"
    exit 1
}
# Replace early error trap with lock cleanup — if we got this far, normal
# error handling (retries, notification dispatch) will handle failures.
trap - ERR
trap 'release_lock "$SCHEDULE_ID"' EXIT

# If this is a Chrome skill, ensure a graphical display and browser are available
if [[ "$use_chrome" == "true" ]]; then
    # Check for a graphical display
    if [[ -z "${DISPLAY:-}" && -z "${WAYLAND_DISPLAY:-}" ]]; then
        log_daemon "RUN ${RUN_ID}: SKIP: Chrome skill '${run_name}' requires a graphical display but none is available (no DISPLAY or WAYLAND_DISPLAY set)"
        exit 0
    fi

    # Verify the display is actually reachable (X server running)
    if [[ -n "${DISPLAY:-}" ]] && ! xdpyinfo &>/dev/null 2>&1; then
        log_daemon "RUN ${RUN_ID}: SKIP: Chrome skill '${run_name}' requires a graphical display but DISPLAY=${DISPLAY} is not reachable"
        exit 0
    fi

    if ! pgrep -f "google-chrome" &>/dev/null; then
        log_daemon "RUN ${RUN_ID}: Chrome skill — no browser detected, launching Google Chrome"
        nohup google-chrome-stable &>/dev/null &
        # Wait for browser to fully start and extension to connect
        sleep 15
        if ! pgrep -f "google-chrome" &>/dev/null; then
            log_daemon "RUN ${RUN_ID}: ERROR: Failed to launch browser for Chrome skill"
            exit 1
        fi
        log_daemon "RUN ${RUN_ID}: Browser launched successfully"
    else
        log_daemon "RUN ${RUN_ID}: Chrome skill — browser already running"
    fi
fi

start_time=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
start_epoch=$(date +%s)

log_daemon "RUN ${RUN_ID}: Starting ${run_type} '${run_name}' in ${workdir}"

attempt=0
exit_code=1
stdout_file="${OUTPUT_DIR}/${RUN_ID}.stdout"
stderr_file="${OUTPUT_DIR}/${RUN_ID}.stderr"

while (( attempt < max_attempts )); do
    attempt=$((attempt + 1))
    log_daemon "RUN ${RUN_ID}: Attempt ${attempt}/${max_attempts}"

    set +e
    if [[ "$run_type" == "skill" ]]; then
        # Build skill prompt (no `local` — we're at top level)
        prompt="/${skill}"
        [[ -n "$args" ]] && prompt="/${skill} ${args}"

        # Invoke Claude Code from the project directory
        chrome_flag=""
        [[ "$use_chrome" == "true" ]] && chrome_flag="--chrome"
        (
            cd "$workdir" 2>/dev/null || cd "$HOME"
            timeout "${timeout_secs}" \
                claude -p \
                    --output-format json \
                    --permission-mode "$permission_mode" \
                    --max-budget-usd "$max_budget" \
                    --no-session-persistence \
                    $chrome_flag \
                    "$prompt"
        ) > "$stdout_file" 2> "$stderr_file" < /dev/null
        exit_code=$?
    elif [[ "$run_type" == "command" ]]; then
        # Run bash command directly
        (
            cd "$workdir" 2>/dev/null || cd "$HOME"
            timeout "${timeout_secs}" \
                bash -c "$command"
        ) > "$stdout_file" 2> "$stderr_file" < /dev/null
        exit_code=$?
    fi
    set -e

    if [[ $exit_code -eq 124 ]]; then
        log_daemon "RUN ${RUN_ID}: Timed out after ${timeout_secs}s"
    fi

    if [[ $exit_code -eq 0 ]]; then
        break
    fi

    if (( attempt < max_attempts )); then
        log_daemon "RUN ${RUN_ID}: Failed (exit ${exit_code}), retrying in ${retry_delay}s"
        sleep "$retry_delay"
    fi
done

end_epoch=$(date +%s)
duration=$((end_epoch - start_epoch))
end_time=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

# Parse output based on type
cost="null"
result_text=""
status="success"

if [[ -f "$stdout_file" ]]; then
    if [[ "$run_type" == "skill" ]]; then
        # Skill output is JSON from Claude
        if jq -e '.total_cost_usd' "$stdout_file" > /dev/null 2>&1; then
            cost=$(jq '.total_cost_usd' "$stdout_file")
            result_text=$(jq -r '.result // ""' "$stdout_file" | head -c 2000)
        fi
        if jq -e '.is_error == true' "$stdout_file" > /dev/null 2>&1; then
            status="failure"
        fi
    elif [[ "$run_type" == "command" ]]; then
        # Command output is raw text
        result_text=$(head -c 2000 "$stdout_file")
    fi
fi

[[ $exit_code -ne 0 ]] && status="failure"

# Truncate large output files (> 100KB) — no `local` at top level
for f in "$stdout_file" "$stderr_file"; do
    if [[ -f "$f" ]]; then
        file_size=$(stat -c%s "$f" 2>/dev/null || stat -f%z "$f" 2>/dev/null || echo 0)
        if (( file_size > 102400 )); then
            truncate -s 102400 "$f"
            echo -e "\n\n[TRUNCATED - output exceeded 100KB]" >> "$f"
        fi
    fi
done

# Write structured log entry (atomic via temp file + append)
log_entry=$(jq -cn \
    --arg run_id "$RUN_ID" \
    --arg schedule_id "$SCHEDULE_ID" \
    --arg type "$run_type" \
    --arg name "$run_name" \
    --arg skill "$skill" \
    --arg command "$command" \
    --arg args "$args" \
    --arg project_path "$workdir" \
    --arg start "$start_time" \
    --arg end "$end_time" \
    --argjson duration "$duration" \
    --argjson exit_code "$exit_code" \
    --arg status "$status" \
    --argjson cost "$cost" \
    --argjson attempts "$attempt" \
    --arg result_preview "$result_text" \
    --arg stdout_file "$stdout_file" \
    --arg stderr_file "$stderr_file" \
    '{
        run_id: $run_id,
        schedule_id: $schedule_id,
        type: $type,
        name: $name,
        skill: $skill,
        command: $command,
        args: $args,
        project_path: $project_path,
        started_at: $start,
        ended_at: $end,
        duration_seconds: $duration,
        exit_code: $exit_code,
        status: $status,
        cost_usd: $cost,
        attempts: $attempts,
        result_preview: $result_preview,
        stdout_file: $stdout_file,
        stderr_file: $stderr_file
    }'
)

echo "$log_entry" >> "$RUNS_LOG"

log_daemon "RUN ${RUN_ID}: ${run_type} '${run_name}' completed (${status}, ${duration}s, exit ${exit_code}, cost \$${cost})"

# --- Notification dispatch ---
# Set notify_* variables for template expansion and dispatch
notify_skill="$run_name"
notify_status="$status"
notify_exit_code="$exit_code"
notify_duration="$duration"
notify_cost="$cost"
notify_attempts="$attempt"
notify_max_attempts="$max_attempts"
notify_project_path="$workdir"
notify_result_preview="${result_text:0:4096}"
notify_result_full="$result_text"
notify_timestamp="$end_time"

dispatch_notification "$schedule_json"
